# ComfyUI Engine - Production Environment Configuration

# Application
COMFYUI_ENV=production
COMFYUI_LOG_LEVEL=warning
COMFYUI_DEBUG=false

# Server
COMFYUI_HOST=0.0.0.0
COMFYUI_PORT=8188
COMFYUI_ENGINE_PORT=8080
COMFYUI_METRICS_PORT=9090

# Database
POSTGRES_HOST=postgres.production.internal
POSTGRES_PORT=5432
POSTGRES_DB=comfyui_prod
POSTGRES_USER=comfyui_prod
POSTGRES_PASSWORD=${PROD_POSTGRES_PASSWORD}
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# Redis
REDIS_HOST=redis.production.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=50

# GPU
CUDA_VISIBLE_DEVICES=0,1,2,3
GPU_MEMORY_FRACTION=0.95
GPU_ALLOW_GROWTH=false

# LLM / Inference
DEFAULT_MODEL=sd-xl
MAX_BATCH_SIZE=16
TIMEOUT=120.0

# Tracing
TRACING_ENABLED=true
OTLP_ENDPOINT=http://jaeger.production.internal:4317
TRACING_SAMPLE_RATE=0.1

# Metrics
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
METRICS_FLUSH_INTERVAL=15.0

# Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=100000
CACHE_TTL=1800

# Security
JWT_SECRET=${PROD_JWT_SECRET}
JWT_EXPIRY=1800
RATE_LIMIT_ENABLED=true
CORS_ORIGINS=https://comfyui-engine.io,https://app.comfyui-engine.io

# Scaling
MIN_WORKERS=5
MAX_WORKERS=50
SCALE_UP_THRESHOLD=0.8
SCALE_DOWN_THRESHOLD=0.2

# Feature Flags
ENABLE_BANDIT=true
ENABLE_PRECOGNITION=true
ENABLE_TRACING=true
ENABLE_CHAOS_TESTING=false

# High Availability
ENABLE_MULTI_REGION=true
PRIMARY_REGION=us-east-1
BACKUP_REGIONS=us-west-2,eu-west-1
FAILOVER_STRATEGY=active-active

# Disaster Recovery
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
RPO_SECONDS=30
RTO_SECONDS=300
