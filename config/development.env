# ComfyUI Engine - Development Environment Configuration

# Application
COMFYUI_ENV=development
COMFYUI_LOG_LEVEL=debug
COMFYUI_DEBUG=true

# Server
COMFYUI_HOST=0.0.0.0
COMFYUI_PORT=8188
COMFYUI_ENGINE_PORT=8080
COMFYUI_METRICS_PORT=9090

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=comfyui_dev
POSTGRES_USER=comfyui_dev
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=10

# GPU
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.8
GPU_ALLOW_GROWTH=true

# LLM / Inference
DEFAULT_MODEL=sd-xl
MAX_BATCH_SIZE=4
TIMEOUT=30.0

# Tracing
TRACING_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
TRACING_SAMPLE_RATE=1.0

# Metrics
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
METRICS_FLUSH_INTERVAL=5.0

# Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL=300

# Security
JWT_SECRET=dev_secret_change_me_in_production
JWT_EXPIRY=3600
RATE_LIMIT_ENABLED=false
CORS_ORIGINS=*

# Scaling
MIN_WORKERS=1
MAX_WORKERS=4
SCALE_UP_THRESHOLD=0.7
SCALE_DOWN_THRESHOLD=0.3

# Feature Flags
ENABLE_BANDIT=true
ENABLE_PRECOGNITION=true
ENABLE_TRACING=true
ENABLE_CHAOS_TESTING=false
