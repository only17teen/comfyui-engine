# ComfyUI Engine - Staging Environment Configuration

# Application
COMFYUI_ENV=staging
COMFYUI_LOG_LEVEL=info
COMFYUI_DEBUG=false

# Server
COMFYUI_HOST=0.0.0.0
COMFYUI_PORT=8188
COMFYUI_ENGINE_PORT=8080
COMFYUI_METRICS_PORT=9090

# Database
POSTGRES_HOST=postgres.staging.internal
POSTGRES_PORT=5432
POSTGRES_DB=comfyui_staging
POSTGRES_USER=comfyui_staging
POSTGRES_PASSWORD=${STAGING_POSTGRES_PASSWORD}
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Redis
REDIS_HOST=redis.staging.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=20

# GPU
CUDA_VISIBLE_DEVICES=0,1
GPU_MEMORY_FRACTION=0.9
GPU_ALLOW_GROWTH=false

# LLM / Inference
DEFAULT_MODEL=sd-xl
MAX_BATCH_SIZE=8
TIMEOUT=60.0

# Tracing
TRACING_ENABLED=true
OTLP_ENDPOINT=http://jaeger.staging.internal:4317
TRACING_SAMPLE_RATE=0.5

# Metrics
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
METRICS_FLUSH_INTERVAL=10.0

# Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=10000
CACHE_TTL=600

# Security
JWT_SECRET=${STAGING_JWT_SECRET}
JWT_EXPIRY=3600
RATE_LIMIT_ENABLED=true
CORS_ORIGINS=https://staging.comfyui-engine.io

# Scaling
MIN_WORKERS=2
MAX_WORKERS=10
SCALE_UP_THRESHOLD=0.75
SCALE_DOWN_THRESHOLD=0.25

# Feature Flags
ENABLE_BANDIT=true
ENABLE_PRECOGNITION=true
ENABLE_TRACING=true
ENABLE_CHAOS_TESTING=true
